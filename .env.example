# Copy this file to .env and fill in your values
# NEVER commit .env to git

ZHS_EMAIL=soumil.bharatendu@gmail.com
ZHS_PASSWORD=your_password_here

# Telegram: create a bot via @BotFather on Telegram → copy the token
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWXyz

# Your personal Telegram chat ID → get it by messaging @userinfobot on Telegram OR just type/send text in the bot and then ping this address https://api.telegram.org/bot<TOKEN>/getupdates and then you can check what your id is from the json you see .....but with this you only get notified on your personal account, no one else gets it
#Get the group's chat ID (send a message to the group, then check https://api.telegram.org/bot<TOKEN>/getUpdates — look for "chat": {"id": -XXXXXXXXX} with a negative number)

TELEGRAM_CHAT_ID=123456789 (would be a negative number for groups)

# How often to check, in seconds (default: 300 = every 5 minutes)
CHECK_INTERVAL_SECONDS=300

# Set to false to watch the browser live (headed mode), true for background running
HEADLESS=true
