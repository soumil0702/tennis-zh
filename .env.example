# Copy this file to .env and fill in your values
# NEVER commit .env to git

ZHS_EMAIL=soumil.bharatendu@gmail.com
ZHS_PASSWORD=your_password_here

# Telegram: create a bot via @BotFather on Telegram → copy the token
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWXyz
# Your personal Telegram chat ID → get it by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=123456789

# How often to check, in seconds (default: 300 = every 5 minutes)
CHECK_INTERVAL_SECONDS=300

# Set to false to watch the browser live (headed mode), true for background running
HEADLESS=true
